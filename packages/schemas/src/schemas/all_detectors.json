{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DetectorsRefactored",
  "description": "Merged detector schemas with all detector types and common definitions",
  "oneOf": [
    {
      "$ref": "#/definitions/ContentDetectorConfig"
    },
    {
      "$ref": "#/definitions/SecretsDetectorConfig"
    },
    {
      "$ref": "#/definitions/PIIDetectorConfig"
    },
    {
      "$ref": "#/definitions/ThreatDetectorConfig"
    },
    {
      "$ref": "#/definitions/BrokenLinksDetectorConfig"
    },
    {
      "$ref": "#/definitions/CustomDetectorConfig"
    },
    {
      "$ref": "#/definitions/SpamDetectorConfig"
    },
    {
      "$ref": "#/definitions/NSFWDetectorConfig"
    },
    {
      "$ref": "#/definitions/PromptInjectionDetectorConfig"
    },
    {
      "$ref": "#/definitions/GenericDetectorConfig"
    }
  ],
  "definitions": {
    "DetectorType": {
      "type": "string",
      "enum": [
        "SECRETS",
        "PII",
        "TOXIC",
        "NSFW",
        "YARA",
        "BROKEN_LINKS",
        "PROMPT_INJECTION",
        "SPAM",
        "LANGUAGE",
        "CODE_SECURITY",
        "CUSTOM"
      ],
      "description": "Type of detector for content analysis"
    },
    "DetectorCategory": {
      "type": "string",
      "enum": [
        "SECURITY",
        "PRIVACY",
        "THREAT",
        "CONTENT",
        "QUALITY",
        "FAIRNESS",
        "COMPLIANCE",
        "CLASSIFICATION"
      ],
      "description": "High-level detector category for filtering and governance"
    },
    "SupportedAssetType": {
      "type": "string",
      "enum": [
        "TXT",
        "TABLE",
        "IMAGE",
        "VIDEO",
        "AUDIO",
        "URL",
        "BINARY",
        "OTHER"
      ],
      "description": "Canonical output asset type the detector can process"
    },
    "SourceAssetType": {
      "type": "string",
      "enum": [
        "WORDPRESS",
        "SLACK",
        "S3_COMPATIBLE_STORAGE",
        "AZURE_BLOB_STORAGE",
        "GOOGLE_CLOUD_STORAGE",
        "POSTGRESQL",
        "MYSQL",
        "JIRA",
        "CONFLUENCE",
        "SERVICEDESK",
        "DATABRICKS",
        "SNOWFLAKE",
        "MONGODB",
        "TABLEAU",
        "MSSQL",
        "ORACLE",
        "HIVE",
        "POWERBI"
      ],
      "description": "Source types where detector execution is supported"
    },
    "DetectorLifecycleStatus": {
      "type": "string",
      "enum": [
        "active",
        "planned",
        "experimental",
        "deprecated"
      ],
      "description": "Implementation lifecycle status of a detector"
    },
    "DetectorPriority": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3",
        "P4"
      ],
      "description": "Roadmap priority for rollout"
    },
    "DetectorCatalogEntry": {
      "type": "object",
      "description": "Catalog metadata for one detector type",
      "properties": {
        "detector_type": {
          "$ref": "#/definitions/DetectorType",
          "description": "Canonical detector identifier"
        },
        "lifecycle_status": {
          "$ref": "#/definitions/DetectorLifecycleStatus"
        },
        "priority": {
          "$ref": "#/definitions/DetectorPriority"
        },
        "categories": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/DetectorCategory"
          },
          "uniqueItems": true,
          "minItems": 1,
          "description": "Detector categories used for routing, reporting, and policy"
        },
        "supported_asset_types": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SupportedAssetType"
          },
          "uniqueItems": true,
          "minItems": 1,
          "description": "Asset modalities the detector can scan"
        },
        "supported_source_types": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SourceAssetType"
          },
          "uniqueItems": true,
          "description": "Optional source-level compatibility list"
        },
        "supported_mime_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true,
          "description": "Optional MIME type compatibility list"
        },
        "recommended_model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Recommended model, engine, or package for this detector"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Implementation notes and constraints"
        }
      },
      "required": [
        "detector_type",
        "lifecycle_status",
        "priority",
        "categories",
        "supported_asset_types"
      ]
    },
    "DetectorCatalog": {
      "type": "array",
      "description": "Detector capability catalog used for planning and runtime routing",
      "items": {
        "$ref": "#/definitions/DetectorCatalogEntry"
      },
      "default": [
        {
          "detector_type": "SECRETS",
          "lifecycle_status": "active",
          "priority": "P0",
          "categories": [
            "SECURITY",
            "COMPLIANCE"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL"
          ],
          "recommended_model": "detect-secrets",
          "notes": "Detects confidential credentials like API keys, tokens, or passwords that could lead to security breaches."
        },
        {
          "detector_type": "PII",
          "lifecycle_status": "active",
          "priority": "P0",
          "categories": [
            "PRIVACY",
            "COMPLIANCE"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL"
          ],
          "recommended_model": "presidio-analyzer",
          "notes": "Identifies personal data (e.g., names, emails, IDs) that must be protected for privacy and compliance."
        },
        {
          "detector_type": "TOXIC",
          "lifecycle_status": "active",
          "priority": "P1",
          "categories": [
            "CONTENT"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL"
          ],
          "recommended_model": "detoxify",
          "notes": "Flags harmful or abusive language that could damage user experience or brand reputation."
        },
        {
          "detector_type": "NSFW",
          "lifecycle_status": "active",
          "priority": "P1",
          "categories": [
            "CONTENT"
          ],
          "supported_asset_types": [
            "IMAGE"
          ],
          "recommended_model": "nudenet",
          "notes": "Detects inappropriate or explicit content not suitable for workplace or general audiences."
        },
        {
          "detector_type": "YARA",
          "lifecycle_status": "active",
          "priority": "P1",
          "categories": [
            "THREAT",
            "SECURITY"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL",
            "BINARY"
          ],
          "recommended_model": "yara-python",
          "notes": "Uses security rules to identify known malware patterns or suspicious file content."
        },
        {
          "detector_type": "BROKEN_LINKS",
          "lifecycle_status": "active",
          "priority": "P2",
          "categories": [
            "QUALITY"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL"
          ],
          "recommended_model": "HTTP validation engine",
          "notes": "Finds non-working or invalid links that reduce content quality and user trust."
        },
        {
          "detector_type": "PROMPT_INJECTION",
          "lifecycle_status": "active",
          "priority": "P0",
          "categories": [
            "SECURITY"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL"
          ],
          "recommended_model": "protectai/deberta-v3-base-prompt-injection-v2",
          "notes": "Detects attempts to manipulate AI systems with malicious or hidden instructions."
        },
        {
          "detector_type": "SPAM",
          "lifecycle_status": "active",
          "priority": "P2",
          "categories": [
            "QUALITY"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL"
          ],
          "recommended_model": "mrm8488/bert-tiny-finetuned-sms-spam-detection",
          "notes": "Flags low-quality or irrelevant bulk content often used for unsolicited promotion."
        },
        {
          "detector_type": "LANGUAGE",
          "lifecycle_status": "active",
          "priority": "P2",
          "categories": [
            "QUALITY"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL"
          ],
          "recommended_model": "fast-langdetect",
          "notes": "Detects the language of the content to support localization and processing rules."
        },
        {
          "detector_type": "CODE_SECURITY",
          "lifecycle_status": "active",
          "priority": "P3",
          "categories": [
            "SECURITY",
            "THREAT"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "OTHER"
          ],
          "recommended_model": "bandit",
          "notes": "Identifies vulnerabilities or insecure patterns in source code (e.g., hardcoded secrets)."
        },
        {
          "detector_type": "CUSTOM",
          "lifecycle_status": "active",
          "priority": "P0",
          "categories": [
            "CLASSIFICATION",
            "COMPLIANCE"
          ],
          "supported_asset_types": [
            "TXT",
            "TABLE",
            "URL",
            "IMAGE"
          ],
          "recommended_model": "mDeBERTa-v3 + SetFit + GLiNER",
          "notes": "User-defined rules tailored to specific business needs or internal policies."
        }
      ]
    },
    "Severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ],
      "description": "Severity level of finding"
    },
    "Location": {
      "type": "object",
      "description": "Location of finding in content",
      "properties": {
        "line": {
          "type": "integer",
          "description": "Line number (1-indexed)"
        },
        "column": {
          "type": "integer",
          "description": "Column number (1-indexed)"
        },
        "start": {
          "type": "integer",
          "description": "Start offset (0-indexed)"
        },
        "end": {
          "type": "integer",
          "description": "End offset (0-indexed)"
        },
        "path": {
          "type": "string",
          "description": "File path or identifier"
        }
      },
      "required": [
        "start",
        "end"
      ]
    },
    "ContentEnabledPattern": {
      "type": "string",
      "enum": [
        "toxicity",
        "severe_toxicity",
        "obscene",
        "threat",
        "insult",
        "identity_attack",
        "nsfw",
        "nsfw_explicit"
      ],
      "description": "Content detector pattern types"
    },
    "SecretsEnabledPattern": {
      "type": "string",
      "enum": [
        "artifactory",
        "aws",
        "azure_storage",
        "basic_auth",
        "cloudant",
        "discord",
        "github",
        "gitlab",
        "high_entropy_base64",
        "high_entropy_hex",
        "ibm_cloud_iam",
        "ibm_cos_hmac",
        "ip_public",
        "jwt",
        "keyword",
        "mailchimp",
        "npm",
        "openai",
        "private_key",
        "pypi",
        "sendgrid",
        "slack",
        "softlayer",
        "square_oauth",
        "stripe",
        "telegram",
        "twilio"
      ],
      "description": "Secrets detector pattern types. Each value maps to a detect-secrets plugin: artifactory=ArtifactoryDetector, aws=AWSKeyDetector, azure_storage=AzureStorageKeyDetector, basic_auth=BasicAuthDetector, cloudant=CloudantDetector, discord=DiscordBotTokenDetector, github=GitHubTokenDetector, gitlab=GitLabTokenDetector, high_entropy_base64=Base64HighEntropyString, high_entropy_hex=HexHighEntropyString, ibm_cloud_iam=IbmCloudIamDetector, ibm_cos_hmac=IbmCosHmacDetector, ip_public=IPPublicDetector, jwt=JwtTokenDetector, keyword=KeywordDetector, mailchimp=MailchimpDetector, npm=NpmDetector, openai=OpenAIDetector, private_key=PrivateKeyDetector, pypi=PypiTokenDetector, sendgrid=SendGridDetector, slack=SlackDetector, softlayer=SoftlayerDetector, square_oauth=SquareOAuthDetector, stripe=StripeDetector, telegram=TelegramBotTokenDetector, twilio=TwilioKeyDetector."
    },
    "PIIEnabledPattern": {
      "type": "string",
      "enum": [
        "CREDIT_CARD",
        "CRYPTO",
        "DATE_TIME",
        "EMAIL_ADDRESS",
        "IBAN_CODE",
        "IP_ADDRESS",
        "NRP",
        "LOCATION",
        "PERSON",
        "PHONE_NUMBER",
        "MEDICAL_LICENSE",
        "URL",
        "US_BANK_NUMBER",
        "US_DRIVER_LICENSE",
        "US_ITIN",
        "US_PASSPORT",
        "US_SSN",
        "UK_NHS",
        "ES_NIF",
        "ES_NIE",
        "IT_FISCAL_CODE",
        "IT_DRIVER_LICENSE",
        "IT_VAR_CODE",
        "IT_PASSPORT",
        "IT_IDENTITY_CARD",
        "SG_NRIC_FIN",
        "SG_UEN",
        "AU_ABN",
        "AU_ACN",
        "AU_TFN",
        "AU_MEDICARE",
        "IN_PAN",
        "IN_AADHAAR",
        "IN_VEHICLE_REGISTRATION",
        "IN_VOTER",
        "FI_PERSONAL_IDENTITY_CODE",
        "PL_PESEL",
        "AT_SVNR",
        "CH_AHV",
        "DE_TAX_ID",
        "EU_NATIONAL_ID"
      ],
      "description": "Presidio entity types for PII detection. Global: CREDIT_CARD, CRYPTO, DATE_TIME, EMAIL_ADDRESS, IBAN_CODE, IP_ADDRESS, NRP, LOCATION, PERSON, PHONE_NUMBER, MEDICAL_LICENSE, URL. USA: US_BANK_NUMBER, US_DRIVER_LICENSE, US_ITIN, US_PASSPORT, US_SSN. UK: UK_NHS. Spain: ES_NIF, ES_NIE. Italy: IT_FISCAL_CODE, IT_DRIVER_LICENSE, IT_VAR_CODE, IT_PASSPORT, IT_IDENTITY_CARD. Singapore: SG_NRIC_FIN, SG_UEN. Australia: AU_ABN, AU_ACN, AU_TFN, AU_MEDICARE. India: IN_PAN, IN_AADHAAR, IN_VEHICLE_REGISTRATION, IN_VOTER. Finland: FI_PERSONAL_IDENTITY_CODE. Poland: PL_PESEL. DACH: AT_SVNR, CH_AHV, DE_TAX_ID, EU_NATIONAL_ID."
    },
    "PIIRecognizerPattern": {
      "type": "object",
      "description": "Regex pattern entry for a custom Presidio recognizer",
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name for this pattern"
        },
        "regex": {
          "type": "string",
          "description": "Regular expression to match the entity"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score assigned when this pattern matches (0-1)"
        }
      },
      "required": [
        "name",
        "regex",
        "score"
      ],
      "additionalProperties": false
    },
    "PIICustomRecognizer": {
      "type": "object",
      "description": "Ad-hoc Presidio recognizer added at runtime. Supports regex patterns, deny-list terms, or both. The recognizer is registered in the analyzer engine and applies to all scans with this config.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique name for this recognizer"
        },
        "supported_entity": {
          "type": "string",
          "description": "Entity label produced when this recognizer fires (e.g. MY_EMPLOYEE_ID)"
        },
        "supported_language": {
          "type": "string",
          "default": "en",
          "description": "BCP-47 language code this recognizer applies to"
        },
        "patterns": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/definitions/PIIRecognizerPattern"
              },
              "minItems": 1
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Regex patterns for this recognizer"
        },
        "deny_list": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Exact-match deny-list terms for this recognizer"
        },
        "context": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Context words that boost the score when found near a match (e.g. ['zip', 'code'])"
        }
      },
      "required": [
        "name",
        "supported_entity"
      ],
      "additionalProperties": false
    },
    "DetectorConfig": {
      "type": "object",
      "description": "Configuration for detector",
      "properties": {
        "enabled_patterns": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "List of enabled pattern names"
        },
        "severity_threshold": {
          "anyOf": [
            {
              "$ref": "#/definitions/Severity"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Minimum severity to report"
        },
        "confidence_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.7,
          "description": "Minimum confidence to report (0-1)"
        },
        "max_findings": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Maximum number of findings to return"
        }
      }
    },
    "ContentDetectorConfig": {
      "title": "ContentDetectorConfig",
      "description": "Configuration for content safety detectors",
      "allOf": [
        {
          "$ref": "#/definitions/DetectorConfig"
        },
        {
          "type": "object",
          "properties": {
            "enabled_patterns": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/ContentEnabledPattern"
              },
              "description": "Specific content types to detect"
            },
            "model_name": {
              "type": "string",
              "enum": [
                "original",
                "unbiased",
                "multilingual"
              ],
              "default": "original",
              "title": "ContentModelName",
              "description": "Detoxify model variant"
            }
          }
        }
      ]
    },
    "SecretsDetectorConfig": {
      "title": "SecretsDetectorConfig",
      "description": "Configuration for secrets detector powered by detect-secrets",
      "allOf": [
        {
          "$ref": "#/definitions/DetectorConfig"
        },
        {
          "type": "object",
          "properties": {
            "enabled_patterns": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/SecretsEnabledPattern"
                  },
                  "minItems": 1
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Subset of detect-secrets plugins to enable. When null all supported plugins are active."
            },
            "entropy_limit_base64": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 8.0
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Entropy threshold for Base64HighEntropyString (0-8). Defaults to detect-secrets built-in of 4.5 when null. Lower values catch more secrets but increase false positives."
            },
            "entropy_limit_hex": {
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 8.0
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Entropy threshold for HexHighEntropyString (0-8). Defaults to detect-secrets built-in of 3.0 when null. Lower values catch more secrets but increase false positives."
            }
          }
        }
      ]
    },
    "PIIDetectorConfig": {
      "title": "PIIDetectorConfig",
      "description": "Configuration for PII detector powered by Microsoft Presidio",
      "allOf": [
        {
          "$ref": "#/definitions/DetectorConfig"
        },
        {
          "type": "object",
          "properties": {
            "enabled_patterns": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/PIIEnabledPattern"
                  }
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Presidio entity types to detect. When null, all supported entities are enabled. Use PIIEnabledPattern values (e.g. EMAIL_ADDRESS, US_SSN, CREDIT_CARD)."
            },
            "language": {
              "type": "string",
              "default": "en",
              "description": "BCP-47 language code for NER models (e.g. en, de, es)"
            },
            "spacy_model": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "spaCy model to load (e.g. en_core_web_sm, en_core_web_lg). Defaults to en_core_web_sm when null."
            },
            "spacy_model_url": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Wheel URL for the spaCy model. When set and the model is not installed, the CLI installs it at runtime."
            },
            "custom_recognizers": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/PIICustomRecognizer"
                  }
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Ad-hoc recognizers added to the Presidio registry at runtime. Each entry defines a regex-pattern or deny-list recognizer for a custom entity type."
            }
          }
        }
      ]
    },
    "ThreatDetectorConfig": {
      "title": "ThreatDetectorConfig",
      "description": "Configuration for threat detector",
      "allOf": [
        {
          "$ref": "#/definitions/DetectorConfig"
        },
        {
          "type": "object",
          "properties": {
            "enabled_patterns": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "YARA rule names to enable"
            },
            "rules_path": {
              "type": "string",
              "description": "Path to custom YARA rules directory"
            },
            "timeout": {
              "type": "integer",
              "default": 60,
              "description": "Timeout for YARA scanning in seconds"
            }
          }
        }
      ]
    },
    "SpamDetectorConfig": {
      "title": "SpamDetectorConfig",
      "description": "Configuration for spam detector",
      "allOf": [
        {
          "$ref": "#/definitions/DetectorConfig"
        },
        {
          "type": "object",
          "properties": {
            "model": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "HuggingFace model ID for spam classification. Defaults to mrm8488/bert-tiny-finetuned-sms-spam-detection when null."
            }
          }
        }
      ]
    },
    "NSFWDetectorConfig": {
      "title": "NSFWDetectorConfig",
      "description": "Configuration for NSFW image detector",
      "allOf": [
        {
