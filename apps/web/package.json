{
  "name": "@classifyre/web",
  "version": "0.2.24",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "codegen": "echo 'API client code generation moved to @workspace/api-client'",
    "test": "bun run test:component",
    "test:component": "playwright test -c playwright-ct.config.ts",
    "test:component:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:e2e": "bun run test:component",
    "test:i18n": "node_modules/.bin/jest lib/i18n-keys.spec.ts --no-coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@react-spring/web": "^10.0.3",
    "@stepperize/core": "^2.0.0",
    "@stepperize/react": "^6.0.0",
    "@workspace/api-client": "workspace:*",
    "@workspace/schemas": "workspace:*",
    "@workspace/ui": "workspace:*",
    "ajv": "^8.18.0",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "lucide-react": "^0.475.0",
    "next": "^16.0.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.5.6",
    "react-rnd": "^10.5.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
