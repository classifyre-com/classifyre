# Database
DATABASE_URL="postgresql://user:password@localhost:5432/classifyre"

# API
PORT=8000
API_URL=http://localhost:8000

# CLI Runner
ENVIRONMENT=development
CLI_PATH=../cli
TEMP_DIR=/tmp
RUNNER_LOGS_DIR=./var/runner-logs

# Masked source config encryption (recommended: a random 32-byte key, base64 encoded)
# Example generation: openssl rand -base64 32
CLASSIFYRE_MASKED_CONFIG_KEY=
# Optional passphrase-based fallback (only if key is not set)
# CLASSIFYRE_MASKED_CONFIG_PASSPHRASE=
# CLASSIFYRE_MASKED_CONFIG_SALT=

# For Docker mode (future)
# ENVIRONMENT=docker
# CLI_PATH=/app/cli

# For Kubernetes mode (future)
# ENVIRONMENT=kubernetes
# CLI_JOB_IMAGE=classifyre/cli:latest
# CLI_NAMESPACE=classifyre
