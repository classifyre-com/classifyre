{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".remote-e2e-spec.ts$",
  "setupFiles": ["<rootDir>/setup-env.ts"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "tsconfig": "./test/tsconfig.e2e.json"
    }]
  },
  "transformIgnorePatterns": [],
  "testTimeout": 240000,
  "forceExit": true,
  "maxWorkers": 1
}
